samples('github:switchangel/breaks')

setCps(170/60/4)

$: sound(`
[-  -  -  - ] [cp -  -  - ] [-  -  -  - ] [cp -  -  - ],
[bd -  -  - ] [bd -  -  - ] [bd -  -  - ] [bd -  -  - ]
`).bank("RolandTR909").gain(0.8)

$: s("breaks/2").fit()
.scrub(irand(8).div(8).seg(8)
.rib("<4 20>",1))
.almostNever(ply("2 | 4"))
.orbit(2).lpf("<6000 2000 1000 4000 2000 1000>")
.gain(1)
._scope()
